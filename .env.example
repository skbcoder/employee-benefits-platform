# Employee Benefits Platform — Environment Variables
# Copy this file to .env and adjust values for your environment.
#
#   cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_HOST_PORT=5433          # Host port mapped to Docker PostgreSQL
DB_PORT=5433                     # Must match POSTGRES_HOST_PORT
DB_HOST=localhost
DB_NAME=employee_benefits_platform
DB_USERNAME=benefits_app
DB_PASSWORD=benefits_app

# ── Enrollment Service (port 8080) ────────────────────────────────────
PUBLISHER_TRANSPORT=http         # http (local) or eventbridge (AWS)
PROCESSING_SERVICE_URL=http://localhost:8081

# ── Processing Service (port 8081) ────────────────────────────────────
ENROLLMENT_SERVICE_URL=http://localhost:8080

# ── AI Platform (optional — only needed for AI chatbot features) ──────
# Set these if you want to run the AI chatbot, MCP server, and RAG pipeline.

# AI Gateway (port 8200)
AI_GATEWAY_API=http://localhost:8200
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
KNOWLEDGE_SERVICE_URL=http://localhost:8300

# Rate limiting
RATE_LIMIT_RPM=20                # Max chat requests per minute per IP

# Audit
AUDIT_LOG_FILE=audit.log

# Refinement
ENABLE_REFINEMENT=true
REFINEMENT_MIN_LENGTH=50

# ── Frontend (port 3000) ──────────────────────────────────────────────
ENROLLMENT_API=http://localhost:8080
PROCESSING_API=http://localhost:8081

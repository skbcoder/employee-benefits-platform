{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "increase(agent_request_total[5m])",
          "legendFormat": "{{agent}} ({{status}})"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      }
    },
    {
      "title": "Request Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "agent_request_duration_seconds_sum / agent_request_duration_seconds_count",
          "legendFormat": "avg ({{agent}})"
        },
        {
          "expr": "histogram_quantile(0.95, rate(agent_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 ({{agent}})"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      }
    },
    {
      "title": "Tool Calls",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(agent_tool_call_total)",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" } }
      }
    },
    {
      "title": "Token Usage",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum(agent_token_usage_total)",
          "legendFormat": "Total Tokens"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "green", "mode": "fixed" } }
      }
    },
    {
      "title": "Guardrail Triggers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(agent_guardrail_trigger_total)",
          "legendFormat": "Total Blocks"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "title": "PII Detections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "sum(pii_detection_total)",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "orange", "mode": "fixed" } }
      }
    },
    {
      "title": "Tool Calls by Name",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "agent_tool_call_total",
          "legendFormat": "{{tool_name}}"
        }
      ]
    },
    {
      "title": "Governance Decisions",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "agent_governance_decision_total",
          "legendFormat": "{{decision}}"
        }
      ]
    },
    {
      "title": "RAG Searches",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum(rag_search_duration_seconds_count)",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "purple", "mode": "fixed" } }
      }
    },
    {
      "title": "RAG Avg Duration",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 20 },
      "targets": [
        {
          "expr": "rag_search_duration_seconds_sum / rag_search_duration_seconds_count",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "purple", "mode": "fixed" }, "unit": "s" }
      }
    },
    {
      "title": "RAG Search Duration (timeline)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "rag_search_duration_seconds_sum / rag_search_duration_seconds_count",
          "legendFormat": "avg ({{service}})"
        },
        {
          "expr": "histogram_quantile(0.95, rate(rag_search_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 ({{service}})"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["ai-platform", "benefits"],
  "templating": { "list": [] },
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "title": "AI Platform - Benefits Orchestrator",
  "uid": "benefits-ai-platform"
}
